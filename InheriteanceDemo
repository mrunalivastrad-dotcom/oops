class Animal{
    String name;
    String sound;

    // Constructor for Superclass
    Animal(String name, String sound) {
        this.name = name;
        this.sound = sound;
    }

    void eat() {
        System.out.println(name + " is eating.");
    }

    void sleep() {
        System.out.println(name + " is sleeping.");
    }

    void makeSound() {
        System.out.println(name + " says: " + sound);
    }

    void displayInfo() {
        System.out.println("Animal Name : " + name);
        System.out.println("Sound       : " + sound);
    }
}

class Dog extends Animal {
    String breed;

    // Constructor for Subclass
    Dog(String name, String breed) {
        super(name, "Woof"); // Calling superclass constructor
        this.breed = breed;
    }

    void fetch() {
        System.out.println(name + " is fetching the ball!");
    }

    // Overriding method to add breed info
    void displayInfo() {
        super.displayInfo(); // Calling superclass method
        System.out.println("Breed       : " + breed);
    }
}

public class InheritanceDemo {
    public static void main(String[] args) {
        
        System.out.println("--- Superclass Object ---");
        Animal a = new Animal("Cat", "Meow");
        a.displayInfo();
        a.eat();
        a.sleep();
        a.makeSound();

        System.out.println("\n--- Subclass Object ---");
        Dog d = new Dog("Bruno", "Labrador");
        d.displayInfo();
        d.eat();
        d.sleep();
        d.makeSound();
        d.fetch();
    }
}
